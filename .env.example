APP_NAME=Laravel
APP_ENV=local
APP_KEY=XXX_CHANGE_ME_XXX
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=XXX_CHANGE_ME_XXX
DB_USERNAME=XXX_CHANGE_ME_XXX
DB_PASSWORD=XXX_CHANGE_ME_XXX

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

#REDIS_HOST=127.0.0.1
#REDIS_PASSWORD=null
#REDIS_PORT=6379

#MAIL_DRIVER=smtp
#MAIL_HOST=smtp.mailtrap.io
#MAIL_PORT=2525
#MAIL_USERNAME=null
#MAIL_PASSWORD=null
#MAIL_ENCRYPTION=null

#PUSHER_APP_ID=
#PUSHER_APP_KEY=
#PUSHER_APP_SECRET=

# Packshot image storage (S3-compatible). See images-migration-proposal.md.
# Localdev defaults below target the MinIO container in docker-compose.
# PACKSHOTS_URL should point at the PROD Spaces CDN so localdev links to prod
# images with no download; MinIO holds only per-game overrides.
# Leave unset to keep every image on the legacy /img/ps-* path (site renders identically).
#PACKSHOTS_KEY=minio
#PACKSHOTS_SECRET=minio123
#PACKSHOTS_REGION=us-east-1
#PACKSHOTS_BUCKET=switchscores-packshots
#PACKSHOTS_ENDPOINT=http://minio:9000
#PACKSHOTS_URL=http://localhost:9100/switchscores-packshots
#PACKSHOTS_USE_PATH_STYLE=true
