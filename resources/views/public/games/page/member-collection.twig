<h2>Your collection</h2>
<p>
    Keep track of the games you own and want to play.
</p>
<div>
    <form method="get" action="{{ route('members.intent.handle', {'action': 'collection-add', 'gameId': GameData.id}) }}" style="display: inline;">
        <button type="submit" class="btn btn-primary">
            <i class="fa fa-plus" aria-hidden="true"></i> Add to collection
        </button>
    </form>
    <form method="get" action="{{ route('members.intent.handle', {'action': 'wishlist-add', 'gameId': GameData.id}) }}" style="display: inline;">
        <button type="submit" class="btn btn-default">
            <i class="fa fa-heart" aria-hidden="true"></i> Add to wishlist
        </button>
    </form>
</div>
