{% import 'ui/components/review/quick-review.twig' as quickReview %}
<h2>Member reviews</h2>
{% if ReviewList.count %}
    {% for item in ReviewList %}
        {{ quickReview.render(item, false, 'b3') }}
    {% endfor %}
{% else %}
    <p>
        No member reviews yet.
    </p>
{% endif %}
<div>
    <form method="get" action="{{ route('members.intent.handle', {'action': 'quick-review', 'gameId': GameData.id}) }}">
        <button type="submit" class="btn btn-primary">
            <i class="fa fa-star" aria-hidden="true"></i> Write a review
        </button>
    </form>
</div>
