{% import 'ui/components/headings/heading.twig' as heading %}
{% import 'ui/components/links/game.twig' as gamelink %}

{% extends 'theme/staff-b5/layout-default.twig' %}

{% block page_inner %}

<div class="row mb-4">
    <div class="col-md-6">
        <table class="table table-sm" style="max-width: 400px;">
            <tbody>
                <tr>
                    <td style="width: 140px;"><strong>Run ID</strong></td>
                    <td>{{ Run.id }}</td>
                </tr>
                <tr>
                    <td><strong>Started</strong></td>
                    <td>{{ Run.started_at|date('d M Y H:i:s') }}</td>
                </tr>
                <tr>
                    <td><strong>Completed</strong></td>
                    <td>{{ Run.completed_at ? Run.completed_at|date('d M Y H:i:s') : '—' }}</td>
                </tr>
                <tr>
                    <td><strong>Duration</strong></td>
                    <td>{{ Run.durationSeconds() is not null ? Run.durationSeconds() ~ 's' : '—' }}</td>
                </tr>
                <tr>
                    <td><strong>Status</strong></td>
                    <td>
                        {% if Run.status == 'completed' %}
                            <span class="badge bg-success">Completed</span>
                        {% elseif Run.status == 'running' %}
                            <span class="badge bg-warning">Running</span>
                        {% else %}
                            <span class="badge bg-danger">Failed</span>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td><strong>Added</strong></td>
                    <td>{{ Counts['added'] ?? 0 }}</td>
                </tr>
                <tr>
                    <td><strong>Updated</strong></td>
                    <td>{{ Counts['updated'] ?? 0 }}</td>
                </tr>
                <tr>
                    <td><strong>Delisted</strong></td>
                    <td>
                        {% if (Counts['delisted'] ?? 0) > 0 %}
                            <span class="text-danger fw-bold">{{ Counts['delisted'] }}</span>
                        {% else %}
                            0
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td><strong>Conflicts</strong></td>
                    <td>
                        {% if (Counts['conflict'] ?? 0) > 0 %}
                            <span class="text-warning fw-bold">{{ Counts['conflict'] }}</span>
                        {% else %}
                            0
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

{{ heading.renderSlick('Log entries') }}

{% set totalEntries = (Counts['added'] ?? 0) + (Counts['updated'] ?? 0) + (Counts['delisted'] ?? 0) + (Counts['conflict'] ?? 0) %}

<form method="get" action="" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label for="eventType" class="form-label mb-0">Event type:</label>
        <select id="eventType" name="eventType" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">All ({{ totalEntries }})</option>
            <option value="added" {% if FilterEventType == 'added' %}selected{% endif %}>Added ({{ Counts['added'] ?? 0 }})</option>
            <option value="updated" {% if FilterEventType == 'updated' %}selected{% endif %}>Updated ({{ Counts['updated'] ?? 0 }})</option>
            <option value="delisted" {% if FilterEventType == 'delisted' %}selected{% endif %}>Delisted ({{ Counts['delisted'] ?? 0 }})</option>
            <option value="conflict" {% if FilterEventType == 'conflict' %}selected{% endif %}>Conflict ({{ Counts['conflict'] ?? 0 }})</option>
        </select>
    </div>
</form>

{% if LogEntries.total > 0 %}

    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>Event</th>
                <th>Title</th>
                <th>Link ID</th>
                <th>Game</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody>
        {% for entry in LogEntries %}
            <tr>
                <td>
                    {% if entry.event_type == 'added' %}
                        <span class="badge bg-success">Added</span>
                    {% elseif entry.event_type == 'updated' %}
                        <span class="badge bg-primary">Updated</span>
                    {% elseif entry.event_type == 'delisted' %}
                        <span class="badge bg-dark">Delisted</span>
                    {% elseif entry.event_type == 'conflict' %}
                        <span class="badge bg-warning text-dark">Conflict</span>
                    {% else %}
                        <span class="badge bg-secondary">{{ entry.event_type }}</span>
                    {% endif %}
                </td>
                <td>{{ entry.title ?? '—' }}</td>
                <td>
                    <a href="{{ route('staff.data-sources.detail', {'sourceId': entry.source_id, 'linkId': entry.link_id}) }}">{{ entry.link_id }}</a>
                </td>
                <td>
                    {% if entry.game and entry.game.id %}
                        {{ gamelink.title(entry.game, 'staff') }}
                    {% elseif entry.game_id %}
                        <span class="text-muted">ID: {{ entry.game_id }}</span>
                    {% elseif entry.link_id in IgnoreIdList %}
                        <span class="badge bg-secondary">Ignored</span>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>
                <td style="white-space: nowrap;">{{ entry.created_at|date('H:i:s') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {{ LogEntries.links()|raw }}

{% else %}
    <p class="text-muted">No entries found{% if FilterEventType %} for event type "{{ FilterEventType }}"{% endif %}.</p>
{% endif %}

{% endblock page_inner %}
