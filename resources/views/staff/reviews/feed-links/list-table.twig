{% if FeedLinks.count > 0 %}
    <table class="table table-responsive table-sm">
        <thead>
        <tr>
            <th class="text-center">#</th>
            <th>Site</th>
            <th class="text-center">Link</th>
            <th class="text-center">Status</th>
            <th class="text-center">Match rate</th>
            <th class="text-center">Historic</th>
            <th class="text-center">Last post</th>
            <th class="text-center">Last run</th>
            <th class="text-center">Options</th>
        </tr>
        </thead>
        <tbody>
        {% for item in FeedLinks %}
            <tr>
                <td class="text-center">
                    {{ item.feed_link_id }}
                </td>
                <td>
                    <a href="{{ route('partners.review-sites.siteProfile', {'linkTitle': item.site.link_title}) }}" target="_blank">
                        {{ item.site.name }}
                    </a>
                </td>
                <td class="text-center">
                    <a href="{{ item.feed_url }}" target="_blank">
                        View
                    </a>
                </td>
                <td class="text-center">
                    {{ item.getFeedStatusDesc() }}
                </td>
                <td class="text-center">
                    {% if item.title_match_rate is null %}
                        {% if item.title_match_rule_pattern is null %}
                            {# No rule is not necessarily a fault: some feeds carry bare game
                               titles and match at import time instead. #}
                            <span class="badge bg-secondary" title="No match rule set. This feed may be matching on raw titles at import.">No rule</span>
                        {% else %}
                            <span class="text-muted" title="No drafts to sample">&mdash;</span>
                        {% endif %}
                    {% else %}
                        {% if item.title_match_rate >= 80 %}
                            {% set rateClass = 'bg-success' %}
                        {% elseif item.title_match_rate >= 50 %}
                            {% set rateClass = 'bg-warning text-dark' %}
                        {% else %}
                            {% set rateClass = 'bg-danger' %}
                        {% endif %}
                        <span class="badge {{ rateClass }}">{{ item.title_match_rate }}%</span>
                        {% if item.title_match_rate_at %}
                            <br><small class="text-muted">{{ item.title_match_rate_at|date('d M Y') }}</small>
                        {% endif %}
                    {% endif %}
                </td>
                <td class="text-center">
                    {% if item.allowHistoric() %}
                        Yes
                    {% else %}
                        No
                    {% endif %}
                </td>
                <td class="text-center">
                    {{ item.site.last_review_date }}
                </td>
                <td style="width: 250px;">
                    <small>
                        {{ item.last_run_status }}
                    </small>
                </td>
                <td class="text-center">
                    <a href="{{ route('staff.reviews.feedLinks.edit', {'linkId': item.feed_link_id}) }}">Edit</a>
                    |
                    <a href="{{ route('staff.reviews.feedLinks.testTitleRule', {'linkId': item.feed_link_id}) }}">Test</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% else %}
    <p>No feed links found.</p>
{% endif %}