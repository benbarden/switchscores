{% extends 'theme/staff-b5/layout-default.twig' %}

{% import 'ui/components/links/game.twig' as gamelink %}

{% block page_inner %}

{% if session('success') %}
    <div class="alert alert-success">{{ session('success') }}</div>
{% endif %}
{% if session('error') %}
    <div class="alert alert-danger">{{ session('error') }}</div>
{% endif %}

{% if not PackshotsConfigured %}
    <div class="alert alert-warning">
        <strong>Packshots storage is not configured.</strong> The <code>PACKSHOTS_*</code>
        environment variables are not set, so migrate/revert are disabled here. This page
        is read-only until object storage (DigitalOcean Spaces) is wired up.
    </div>
{% endif %}

<p class="text-muted">
    Packshots → object storage POC. The lowest {{ PocLimit }} Switch 2 games.
    <strong>Move to Spaces</strong> copies both packshots onto the <code>packshots</code>
    disk (MinIO in localdev) and flips the game to <code>spaces</code>.
    <strong>Move back</strong> deletes the bucket objects and returns to the legacy
    <code>/img/ps-*</code> files (which are never touched, so it is lossless).
    The thumbnail is served through the resolver, so it reflects the live source.
</p>

<table class="table table-sm table-hover align-middle">
    <thead>
        <tr>
            <th class="text-center">ID</th>
            <th class="text-center">Square</th>
            <th>Title</th>
            <th class="text-center">Location</th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody>
        {% for game in Games %}
            {% set location = game.images ? game.images.location : 'legacy' %}
            <tr>
                <td class="text-center">{{ game.id }}</td>
                <td class="text-center">
                    {% set squareUrl = packshot_url(game, 'square')|trim %}
                    {% if squareUrl %}
                        <img src="{{ squareUrl }}" alt="{{ game.title }}" style="width: 48px; height: 48px; object-fit: cover;">
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>
                <td>{{ gamelink.title(game, 'staff') }}</td>
                <td class="text-center">
                    {% if location == 'spaces' %}
                        <span class="badge bg-success">spaces</span>
                    {% else %}
                        <span class="badge bg-secondary">legacy</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    {% if location == 'spaces' %}
                        <form method="POST" action="{{ route('staff.games.image-migration.revert', {'gameId': game.id}) }}">
                            {{ csrf_field()|raw }}
                            <button type="submit" class="btn btn-sm btn-outline-secondary"{% if not PackshotsConfigured %} disabled{% endif %}>Move back</button>
                        </form>
                    {% else %}
                        <form method="POST" action="{{ route('staff.games.image-migration.migrate', {'gameId': game.id}) }}">
                            {{ csrf_field()|raw }}
                            <button type="submit" class="btn btn-sm btn-primary"{% if not PackshotsConfigured %} disabled{% endif %}>Move to Spaces</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

{% endblock %}
