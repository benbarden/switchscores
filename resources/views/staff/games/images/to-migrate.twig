{% extends 'theme/staff-b5/layout-default.twig' %}

{% import 'ui/components/links/game.twig' as gamelink %}
{% import 'ui/components/game/console-badge.twig' as consolebadge %}
{% import "ui/components/headings/heading.twig" as heading %}

{% block page_inner %}

{% if session('success') %}
    <div class="alert alert-success">{{ session('success') }}</div>
{% endif %}
{% if session('error') %}
    <div class="alert alert-danger">{{ session('error') }}</div>
{% endif %}

{% if not PackshotsConfigured %}
    <div class="alert alert-warning">
        <strong>Packshots storage is not configured.</strong> The <code>PACKSHOTS_*</code>
        environment variables are not set, so migrate/revert are disabled here. This page
        is read-only until object storage is wired up.
    </div>
{% endif %}

<form method="GET" class="mb-4 d-flex align-items-center gap-2">
    <label class="mb-0">Console:</label>
    <select name="console" class="form-select" style="width: auto;" onchange="this.form.submit()">
        <option value="">All</option>
        {% for id, name in ConsoleOptions %}
            <option value="{{ id }}"{% if ConsoleFilter == id %} selected{% endif %}>{{ name }}</option>
        {% endfor %}
    </select>
    <noscript><button type="submit" class="btn btn-sm btn-secondary">Filter</button></noscript>
</form>

{{ heading.renderSlick('To be migrated') }}

<div class="d-flex justify-content-between align-items-center mb-2">
    <span class="text-muted">{{ Unmigrated.total|number_format }} games remaining{% if ConsoleFilter %} (filtered){% endif %} &mdash; oldest first.</span>
    <form method="POST" action="{{ route('staff.games.images.migration.migrateBatch') }}">
        {{ csrf_field()|raw }}
        {% if ConsoleFilter %}<input type="hidden" name="console" value="{{ ConsoleFilter }}">{% endif %}
        <button type="submit" class="btn btn-primary"{% if not PackshotsConfigured or Unmigrated.total == 0 %} disabled{% endif %}>Migrate next {{ BatchSize }}</button>
    </form>
</div>

{% if Unmigrated.total > 0 %}
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th class="text-center">ID</th>
                <th class="text-center">Square</th>
                <th>Title</th>
                <th class="text-center">Console</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody>
            {% for game in Unmigrated %}
                <tr>
                    <td class="text-center">{{ game.id }}</td>
                    <td class="text-center">
                        {% set squareUrl = packshot_url(game, 'square')|trim %}
                        {% if squareUrl %}
                            <img src="{{ squareUrl }}" alt="{{ game.title }}" style="width: 48px; height: 48px; object-fit: cover;">
                        {% else %}
                            <span class="text-muted">&mdash;</span>
                        {% endif %}
                    </td>
                    <td>{{ gamelink.title(game, 'staff') }}</td>
                    <td class="text-center">{{ consolebadge.short(game) }}</td>
                    <td class="text-center">
                        <form method="POST" action="{{ route('staff.games.images.migration.migrate', {'gameId': game.id}) }}">
                            {{ csrf_field()|raw }}
                            <button type="submit" class="btn btn-sm btn-primary"{% if not PackshotsConfigured %} disabled{% endif %}>Migrate</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {{ Unmigrated.links('pagination::bootstrap-5')|raw }}
{% else %}
    <p class="text-muted">Nothing left to migrate for this filter.</p>
{% endif %}

{% endblock %}
