{% extends 'theme/staff-b5/layout-default.twig' %}

{% import 'ui/components/links/game.twig' as gamelink %}
{% import 'ui/components/game/console-badge.twig' as consolebadge %}

{% block page_inner %}

{% if session('success') %}
    <div class="alert alert-success">{{ session('success') }}</div>
{% endif %}
{% if session('error') %}
    <div class="alert alert-danger">{{ session('error') }}</div>
{% endif %}

<p class="text-muted">
    Games currently in object storage, newest first. Use <strong>Move back</strong> to undo a
    migration &mdash; it deletes the stored object and returns the game to the legacy file
    (which is untouched on disk, so it is lossless).
</p>

{% if RecentlyMigrated.total > 0 %}
    <p class="text-muted small">{{ RecentlyMigrated.total|number_format }} games in object storage.</p>
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th class="text-center">ID</th>
                <th class="text-center">Square</th>
                <th>Title</th>
                <th class="text-center">Console</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody>
            {% for image in RecentlyMigrated %}
                {% if image.game %}
                    {% set game = image.game %}
                    <tr>
                        <td class="text-center">{{ game.id }}</td>
                        <td class="text-center">
                            {% set squareUrl = packshot_url(game, 'square')|trim %}
                            {% if squareUrl %}
                                <img src="{{ squareUrl }}" alt="{{ game.title }}" style="width: 48px; height: 48px; object-fit: cover;">
                            {% else %}
                                <span class="text-muted">&mdash;</span>
                            {% endif %}
                        </td>
                        <td>{{ gamelink.title(game, 'staff') }}</td>
                        <td class="text-center">{{ consolebadge.short(game) }}</td>
                        <td class="text-center">
                            <form method="POST" action="{{ route('staff.games.images.migration.revert', {'gameId': game.id}) }}">
                                {{ csrf_field()|raw }}
                                <button type="submit" class="btn btn-sm btn-outline-secondary"{% if not PackshotsConfigured %} disabled{% endif %}>Move back</button>
                            </form>
                        </td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
    {{ RecentlyMigrated.links('pagination::bootstrap-5')|raw }}
{% else %}
    <p class="text-muted">No games migrated yet.</p>
{% endif %}

{% endblock %}
