{% extends 'theme/staff-b5/layout-default.twig' %}

{% block page_inner %}

{% include 'staff/games/weekly-updates/list/_stage-nav.twig' %}

{% if session('success') %}
    <div class="alert alert-success">{{ session('success') }}</div>
{% endif %}
{% if session('error') %}
    <div class="alert alert-danger">{{ session('error') }}</div>
{% endif %}

{% if RawPages|length == 0 %}
    <p class="text-muted">No pages have been uploaded yet. <a href="{{ route('staff.games.weekly-updates.list.raw', {'batchId': Batch.id, 'console': Console, 'listType': ListType}) }}">Go to Raw input</a> to add pages.</p>
{% else %}

    {# Collect skipped and out-of-range across all pages while rendering active tables #}
    {% set allSkippedItems = [] %}
    {% set allOutOfRangeItems = [] %}

    {% for page in RawPages %}
        {% set allPageItems = ItemsByPage[page.page_number] ?? [] %}

        {% set activeItems = [] %}
        {% set skippedItems = [] %}
        {% set outOfRangeItems = [] %}
        {% for item in allPageItems %}
            {% if item.item_status == 'out_of_range' %}
                {% set outOfRangeItems = outOfRangeItems|merge([item]) %}
                {% set allOutOfRangeItems = allOutOfRangeItems|merge([item]) %}
            {% elseif item.item_status in ['excluded', 'low_quality', 'bundle', 'already_in_db'] %}
                {% set skippedItems = skippedItems|merge([item]) %}
                {% set allSkippedItems = allSkippedItems|merge([item]) %}
            {% else %}
                {% set activeItems = activeItems|merge([item]) %}
            {% endif %}
        {% endfor %}

        <h2 class="mt-4">Page {{ page.page_number }}</h2>

        <form method="post" action="{{ route('staff.games.weekly-updates.list.urls.save', {'batchId': Batch.id, 'console': Console, 'listType': ListType}) }}">
            {{ csrf_field()|raw }}
            <input type="hidden" name="page_number" value="{{ page.page_number }}">

            <table class="table table-sm table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 35%;">Title</th>
                        <th class="text-center" style="width: 10%;">Date</th>
                        <th>Nintendo URL</th>
                        <th class="text-center" style="width: 10%;">Nintendo page</th>
                    </tr>
                </thead>
                <tbody>
                {% for item in activeItems %}
                    <tr>
                        <td class="align-middle">{{ item.title }}</td>
                        <td class="text-center align-middle" style="white-space: nowrap;">
                            {{ item.release_date ? item.release_date|date('d M Y') : '—' }}
                        </td>
                        <td class="align-middle">
                            <input type="text"
                                   name="urls[{{ item.id }}]"
                                   value="{{ item.nintendo_url ?? '' }}"
                                   class="form-control form-control-sm{{ item.nintendo_url ? ' is-valid' : '' }}"
                                   placeholder="https://www.nintendo.com/en-gb/Games/...">
                        </td>
                        <td class="text-center align-middle">
                            {% if item.nintendo_url %}
                                <a href="{{ item.nintendo_url }}" target="_blank" class="small" tabindex="-1">Open ↗</a>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <button type="submit" class="btn btn-primary btn-sm mb-4">Save URLs for page {{ page.page_number }}</button>
        </form>

    {% endfor %}

    {# ---- Combined skipped items (all pages) ---- #}
    {% if allSkippedItems|length > 0 %}
    <h2 class="mt-4">Skipped items</h2>
    <p class="text-muted small mb-2">These items have been marked as excluded, low quality, or a bundle. Use the dropdown to reset if needed.</p>
    <table class="table table-sm table-bordered text-muted">
        <thead class="table-dark">
            <tr>
                <th class="text-center" style="width: 6%;">Page</th>
                <th>Title</th>
                <th class="text-center" style="width: 12%;">Date</th>
                <th class="text-center" style="width: 13%;">Status</th>
                <th style="width: 13%;"></th>
            </tr>
        </thead>
        <tbody>
        {% for item in allSkippedItems %}
            <tr class="text-muted">
                <td class="text-center">{{ item.page_number }}</td>
                <td>{{ item.title }}</td>
                <td class="text-center" style="white-space: nowrap;">
                    {{ item.release_date ? item.release_date|date('d M Y') : '—' }}
                </td>
                <td class="text-center">
                    {% if item.item_status == 'excluded' %}
                        <span class="badge bg-secondary">Excluded</span>
                    {% elseif item.item_status == 'low_quality' %}
                        <span class="badge bg-danger">Low quality</span>
                    {% elseif item.item_status == 'bundle' %}
                        <span class="badge bg-info text-dark">Bundle</span>
                    {% elseif item.item_status == 'already_in_db' %}
                        <span class="badge bg-secondary">Already in DB</span>
                    {% endif %}
                </td>
                <td>
                    <form method="post" action="{{ route('staff.games.weekly-updates.list.item.action', {'batchId': Batch.id, 'console': Console, 'listType': ListType, 'itemId': item.id}) }}">
                        {{ csrf_field()|raw }}
                        <select name="action" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="">Change…</option>
                            <option value="low_quality">Low quality</option>
                            <option value="bundle">Bundle</option>
                            <option value="excluded">Exclude (other reason)</option>
                            <option value="reset">Reset</option>
                        </select>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {# ---- Games out of range (per page) ---- #}
    {% if allOutOfRangeItems|length > 0 %}
    <h2 class="mt-4">Games out of range</h2>
    <p class="text-muted small mb-2">These games are outside of the current date range. They will be excluded from this batch.</p>
    <table class="table table-sm table-bordered text-muted" style="max-width: 640px;">
        <thead class="table-dark">
            <tr>
                <th class="text-center" style="width: 8%;">Page</th>
                <th>Title</th>
                <th class="text-center" style="width: 12%;">Date</th>
            </tr>
        </thead>
        <tbody>
        {% for item in allOutOfRangeItems %}
            <tr>
                <td class="text-center">{{ item.page_number }}</td>
                <td>{{ item.title_raw }}</td>
                <td class="text-center" style="white-space: nowrap;">
                    {{ item.release_date ? item.release_date|date('d M Y') : '—' }}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <hr class="mt-2">

    {% set pendingCount = Counts['pending'] ?? 0 %}
    {% if pendingCount == 0 %}
        <a href="{{ route('staff.games.weekly-updates.list.fetch', {'batchId': Batch.id, 'console': Console, 'listType': ListType}) }}" class="btn btn-success">Continue to Fetch →</a>
    {% else %}
        <a href="{{ route('staff.games.weekly-updates.list.fetch', {'batchId': Batch.id, 'console': Console, 'listType': ListType}) }}" class="btn btn-outline-secondary">Continue to Fetch → <small>({{ pendingCount }} item{{ pendingCount != 1 ? 's' : '' }} still need a URL)</small></a>
    {% endif %}

{% endif %}

{% endblock page_inner %}
