{% extends 'theme/staff-b5/layout-default.twig' %}

{% block page_inner %}

<div class="mb-3">
    <a href="{{ route('staff.games.weekly-updates.create') }}" class="btn btn-primary">New batch</a>
</div>

{% if Batches.count > 0 %}
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th class="text-center">S2 New</th>
                <th class="text-center">S2 Upcoming</th>
                <th class="text-center">S1 New</th>
                <th class="text-center">S1 Upcoming</th>
            </tr>
        </thead>
        <tbody>
        {% for batch in Batches %}
            <tr>
                <td><a href="{{ route('staff.games.weekly-updates.show', {'batchId': batch.id}) }}">{{ batch.batch_date|date('d M Y') }}</a></td>
                {% set c = AllCounts[batch.id] ?? {} %}
                {% set totalImported = 0 %}
                {% set totalPending = 0 %}
                {% for con in ['switch-2', 'switch-1'] %}
                    {% for lt in ['new', 'upcoming'] %}
                        {% set lc2 = c[con][lt] ?? {} %}
                        {% set totalImported = totalImported + (lc2['imported'] ?? 0) %}
                        {% set totalPending = totalPending + (lc2['pending'] ?? 0) + (lc2['fetch_pending'] ?? 0) + (lc2['lq_review'] ?? 0) + (lc2['packshot_pending'] ?? 0) + (lc2['category_pending'] ?? 0) + (lc2['ready'] ?? 0) %}
                    {% endfor %}
                {% endfor %}
                <td>
                    {% if totalImported > 0 and totalPending == 0 %}
                        <span class="badge bg-success">Complete</span>
                    {% elseif totalImported > 0 or totalPending > 0 %}
                        <span class="badge bg-primary">In progress</span>
                    {% else %}
                        <span class="badge bg-secondary">Setup</span>
                    {% endif %}
                </td>
                {% for console in ['switch-2', 'switch-1'] %}
                    {% for listType in ['new', 'upcoming'] %}
                        {% set lc = c[console][listType] ?? {} %}
                        {% set imported = lc['imported'] ?? 0 %}
                        {% set ready = lc['ready'] ?? 0 %}
                        {% set lq = lc['low_quality'] ?? 0 %}
                        {% set bundle = lc['bundle'] ?? 0 %}
                        {% set excluded = lq + bundle %}
                        <td class="text-center small">
                            {% if imported > 0 %}<span class="text-success">{{ imported }} imported</span>{% endif %}
                            {% if ready > 0 %}<br><span class="text-primary">{{ ready }} ready</span>{% endif %}
                            {% if excluded > 0 %}<br><span class="text-muted">{{ excluded }} excluded</span>{% endif %}
                            {% if imported == 0 and ready == 0 and excluded == 0 %}—{% endif %}
                        </td>
                    {% endfor %}
                {% endfor %}
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {{ Batches.links()|raw }}
{% else %}
    <p class="text-muted">No weekly batches yet.</p>
{% endif %}

{% endblock page_inner %}
