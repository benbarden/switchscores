{% include 'ui/components/alerts/form-errors.twig' %}
{% import 'ui/components/game/packshots.twig' as packshots %}
{% if FormMode != 'add' %}
<p>
    If you don't own this game anymore, or you added it in error, you can delete it.
    You can easily add a new game to your collection instead.
</p>
{% endif %}
<form role="form" method="post" action="{{ formSubmitAction }}">
    {{ csrf_field() }}

    {% if FormMode == 'add' %}
        <input type="hidden" id="game_id" name="game_id" value="{{ UrlGameId }}">
    {% endif %}
    <fieldset>
        <legend>Basic details</legend>
        <div class="mb-3 row">
            <label for="game_id" class="col-md-4 col-form-label">Game</label>
            <div class="col-md-6">
                <span class="form-control-plaintext">{{ CollectionGame.title }}</span>
            </div>
        </div>

        <div class="mb-3 row">
            <label class="col-md-4 col-form-label">Play status</label>
            <div class="col-md-6">
                {% for item in PlayStatusList %}
                    <div class="form-check">
                        <input class="form-check-input" id="play_status_{{ item.id }}" name="play_status" value="{{ item.id }}" type="radio">
                        <label class="form-check-label" for="play_status_{{ item.id }}">
                            <i class="fas fa-{{ item.icon }}" style="color: {{ item.iconColor }}; font-size: 24px;"></i>
                            {{ item.desc }}
                        </label>
                    </div>
                {% endfor %}
            </div>
            <div class="col-md-2">
                {{ packshots.square(CollectionGame) }}
            </div>
        </div>
    </fieldset>

    <fieldset>
        <legend>Optional extras</legend>
        <div class="mb-3 row">
            <label class="col-md-4 col-form-label">Owned type</label>
            <div class="col-md-6">
                <div class="form-check">
                    <input class="form-check-input" id="owned_type_none" name="owned_type" value="" type="radio">
                    <label class="form-check-label" for="owned_type_none">
                        Not specified
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" id="owned_type_digital" name="owned_type" value="Digital" type="radio">
                    <label class="form-check-label" for="owned_type_digital">
                        Digital
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" id="owned_type_physical" name="owned_type" value="Physical" type="radio">
                    <label class="form-check-label" for="owned_type_physical">
                        Physical
                    </label>
                </div>
            </div>
        </div>

        <div class="mb-3 row">
            <label for="owned_from" class="col-md-4 col-form-label">Owned from</label>
            <div class="col-md-6">
                <input id="owned_from" type="date" class="form-control" name="owned_from">
                <div class="form-text">
                    The date that you got this game. Leave blank if you're not sure.
                </div>
            </div>
        </div>

        <div class="mb-3 row">
            <label for="hours_played" class="col-md-4 col-form-label">Hours played</label>
            <div class="col-md-6">
                <input id="hours_played" type="text" class="form-control" name="hours_played">
                <div class="form-text">
                    The number of hours you've played this game for. You can find this on the Switch itself -
                    go to your profile and you'll see a list of times.
                </div>
            </div>
        </div>
    </fieldset>

    <div class="mb-3 row">
        <div class="col-md-8 offset-md-4">
            <button type="submit" class="btn btn-primary">
                Submit
            </button>
        </div>
    </div>
</form>
