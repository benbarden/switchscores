<div class="alert alert-info">
    You're suggesting a game to be featured at Switch Scores.
    The game is: <strong>{{ GameData.title }}</strong>.
</div>
{% include 'ui/components/alerts/form-errors.twig' %}
{% import 'ui/components/game/packshots.twig' as packshots %}
<form role="form" method="post" action="{{ formSubmitAction }}">
    {{ csrf_field() }}

    <div class="mb-3 row">
        <label class="col-md-2 col-form-label">Featured type</label>
        <div class="col-md-6">
            <p>
                What do you think makes this game worth being featured?
            </p>
            <div class="form-check">
                <input class="form-check-input" id="featured_type_interesting" name="featured_type" value="1" type="radio">
                <label class="form-check-label" for="featured_type_interesting">
                    Interesting
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" id="featured_type_hidden_gem" name="featured_type" value="2" type="radio">
                <label class="form-check-label" for="featured_type_hidden_gem">
                    Hidden gem
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" id="featured_type_unusual" name="featured_type" value="3" type="radio">
                <label class="form-check-label" for="featured_type_unusual">
                    Unusual or unique
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" id="featured_type_needs_more_reviews" name="featured_type" value="4" type="radio">
                <label class="form-check-label" for="featured_type_needs_more_reviews">
                    Needs more reviews <em>- note: currently, it has {{ GameData.review_count }} review(s).</em>
                </label>
            </div>
        </div>
        <div class="col-md-2">
            {{ packshots.square(GameData) }}
        </div>
    </div>

    <div class="mb-3 row">
        <div class="col-md-8 offset-md-4">
            <button type="submit" class="btn btn-primary">
                Submit
            </button>
        </div>
    </div>
</form>
