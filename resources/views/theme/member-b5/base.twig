<!doctype html>
<html lang="{{ config('app.locale') }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <script src="/js/jquery-3.2.1.min.js" type="text/javascript"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- CSRF Token -->
    <meta name="csrf-token" content="{{ csrf_token() }}">

    <title>{{ TopTitle }} | Switch Scores</title>

    <!-- Select2 -->
    <link href="/js/select2/css/select2.min.css" rel="stylesheet" />
    <script src="/js/select2/js/select2.min.js"></script>

    <!-- jQuery UI -->
    <script src="/js/jquery-ui-1.12.1.min.js"></script>
    <link href="/css/jquery-ui-1.12.1.min.css" rel="stylesheet" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-KyZXEAg3QhqLMpG8r+8fhAXLRk2vvoC2f3B09zVXn8CA5QIVfZOJ3BCsw2P0p/We" crossorigin="anonymous">

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css?family=Fira+Sans:400,500,700|Open+Sans:400,400i,600,600i,700,700i" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Noto+Sans+KR:400,700" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300&display=swap" rel="stylesheet">

    <!-- Switch Scores custom code -->
    <link href="{{ asset('member-b5/custom.css') }}?v=260308b" rel="stylesheet">
    <script src="{{ asset('js/ssAdminTools.js') }}?v=240505a"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.0.13/css/all.css" integrity="sha384-DNOHZ68U8hZfKXOrtjWvjxusGo9WQnrNx2sqG0tfsghAvtVlRW3tvkXWZh58N9jp" crossorigin="anonymous">

    {% if siteEnv == 'prod' %}
        <script>
            (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
                (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
                m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
            })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

            ga('create', 'UA-3185140-40', 'auto');
            ga('send', 'pageview');
        </script>
    {% endif %}
</head>
<body>

    {% set currentPath = app.request.pathInfo %}
    {% set inDevelopers = (currentPath starts with '/members/developers') %}
    {% set inMembers = (currentPath starts with '/members') and not inDevelopers %}
    {% set inReviewers = (currentPath starts with '/reviewers') %}
    {% set inGamesCompanies = (currentPath starts with '/games-companies') %}
    {% set inStaff = (currentPath starts with '/staff') %}

    <nav class="navbar navbar-expand-lg navbar-dark navbar-primary">
        <div class="container">
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="navbar-brand" href="{{ url('/') }}">
                            &lt; back to {{ config('app.name', 'Laravel') }}
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link{% if inMembers %} active{% endif %}" href="{{ route('members.index') }}">Members</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link{% if inDevelopers %} active{% endif %}" href="{{ route('members.developers.index') }}">Developers</a>
                    </li>
                    {% if auth_user().isReviewer() %}
                        <li class="nav-item">
                            <a class="nav-link{% if inReviewers %} active{% endif %}" href="{{ route('reviewers.index') }}">Reviewers</a>
                        </li>
                    {% endif %}
                    {% if auth_user().isGamesCompany() %}
                        <li class="nav-item">
                            <a class="nav-link{% if inGamesCompanies %} active{% endif %}" href="{{ route('games-companies.index') }}">Games companies</a>
                        </li>
                    {% endif %}
                    {% if auth_user().isStaff() %}
                        <li class="nav-item">
                            <a class="nav-link{% if inStaff %} active{% endif %}" href="{{ route('staff.index') }}">Staff</a>
                        </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ route('logout') }}"
                           onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                            Logout
                        </a>
                    </li>
                </ul>
                <form id="logout-form" action="{{ route('logout') }}" method="POST" style="display: none;">
                    {{ csrf_field() }}
                </form>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </nav>

    {# Secondary navigation - contextual links based on current section #}
    {% if inMembers or inDevelopers or inReviewers or inGamesCompanies %}
        <nav class="navbar navbar-expand-lg navbar-secondary py-1">
            <div class="container justify-content-start">
                <span class="navbar-text fw-bold me-2">
                    {% if inMembers %}Members:
                    {% elseif inDevelopers %}Developers:
                    {% elseif inReviewers %}Reviewers:
                    {% elseif inGamesCompanies %}Games companies:
                    {% endif %}
                </span>
                <ul class="navbar-nav">
                    {% if inMembers %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.index') }}">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.game-finder.index') }}">Find a game</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.wishlist.index') }}">Wishlist</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.collection.landing') }}">Collection</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.collection.quickAdd') }}">Add to collection</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.quick-reviews.list') }}">Quick reviews</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.settings') }}">Settings</a>
                        </li>
                    {% elseif inDevelopers %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.index') }}">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.api.guide') }}">API guide</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.api.methods') }}">API methods</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.api.tokens') }}">API tokens</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.switch-weekly') }}">Switch Weekly</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('members.developers.hanafuda-report') }}">Hanafuda Report</a>
                        </li>
                    {% elseif inReviewers %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.index') }}">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.reviews.landing') }}">Your reviews</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.feed-health.landing') }}">Feed health</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.stats.landing') }}">Stats</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.unranked-games.list', {'mode': 'by-count', 'filter': 2}) }}">Unranked games</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('reviewers.profile.edit') }}">Edit profile</a>
                        </li>
                    {% elseif inGamesCompanies %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('games-companies.index') }}">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ route('games-companies.profile.edit') }}">Edit profile</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </nav>
    {% endif %}

    {# Email verification banner #}
    {% if auth_user() and not auth_user().isEmailVerified() %}
        <div class="alert alert-warning alert-dismissible mb-0 rounded-0" role="alert">
            <div class="container">
                <strong>Your email is not verified.</strong>
                To add games to your collection and use all features, please verify your email.
                <form action="{{ route('members.email.send-verification') }}" method="POST" class="d-inline">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-warning btn-sm ms-2">Send verification email</button>
                </form>
            </div>
        </div>
    {% endif %}

    <div class="container">
        {# Flash messages #}
        {% if app.session.has('success') %}
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                {{ app.session.get('success') }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endif %}
        {% if app.session.has('error') %}
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                {{ app.session.get('error') }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endif %}

        {% block page_body %}
        {% endblock page_body %}
    </div>
    <footer class="footer mt-auto py-3 bg-light">
        <div class="container">
            <span class="text-muted">
                <small>
                    <strong>Feedback:</strong>
                    How are you finding the Members dashboard? Let us know what you think via
                    <a href="https://bsky.app/profile/switchscores.bsky.social" target="_blank">Bluesky</a>,
                    <a href="http://twitter.com/switchscores" target="_blank">Twitter</a>, or
                    <a href="mailto:ben@switchscores.com?Member dashboard feedback" target="_blank">email</a>.
                </small>
            </span>
        </div>
    </footer>

    <script src="/js/select2-fix.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-U1DAWAznBHeqEIlVSCgzq+c9gqGAJn5c/t99JyeKa9xxaYpSvHU5awsuZVVFIhvj" crossorigin="anonymous"></script>

    <script src="https://unpkg.com/htmx.org@1.9.0"></script>

</body>
</html>
